    </Project>
    <Project Path="src/BgRecorder.Data/BgRecorder.Data.csproj">
      <Platform Solution="*|Any CPU" Project="x64" />
    </Project>
    <Project Path="src/BgRecorder.Logs/BgRecorder.Logs.csproj">
      <Platform Solution="*|Any CPU" Project="x64" />
    </Project>
    <Project Path="src/BgRecorder.Session/BgRecorder.Session.csproj">
      <Platform Solution="*|Any CPU" Project="x64" />
