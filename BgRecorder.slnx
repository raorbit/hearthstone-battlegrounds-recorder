<Solution>
  <!-- Everything maps Any CPU -> x64: ScreenRecorderLib ships per-arch native DLLs and errors on AnyCPU -->
  <Folder Name="/src/">
    <Project Path="src/BgRecorder.App/BgRecorder.App.csproj">
      <Platform Solution="*|Any CPU" Project="x64" />
    </Project>
    <Project Path="src/BgRecorder.Audio/BgRecorder.Audio.csproj">
      <Platform Solution="*|Any CPU" Project="x64" />
    </Project>
