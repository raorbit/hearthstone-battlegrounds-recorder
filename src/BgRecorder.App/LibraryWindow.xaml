<Window x:Class="BgRecorder.App.LibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Battlegrounds Recorder"
        Width="1280"
        Height="800"
        MinWidth="960"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#0E0F12">
    <Grid>
        <wv2:WebView2 x:Name="WebView" DefaultBackgroundColor="#0E0F12" />

        <Border x:Name="ErrorPanel"
                Visibility="Collapsed"
                Background="#0E0F12"
                Padding="48">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="620">
                <TextBlock Text="The library could not be opened"
                           Foreground="#E6E8EE"
                           FontSize="24"
                           FontWeight="SemiBold"
                           TextAlignment="Center" />
                <TextBlock x:Name="ErrorMessage"
                           Margin="0,14,0,0"
                           Foreground="#9AA0AD"
                           FontSize="14"
                           TextWrapping="Wrap"
                           TextAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
